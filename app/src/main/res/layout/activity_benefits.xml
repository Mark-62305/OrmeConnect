<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F1"
    android:forceDarkAllowed="false">

    <!-- ── App Bar ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:contentScrim="#FFFFFF"
            app:statusBarScrim="#FFFFFF">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero"
                app:layout_collapseMode="parallax" />

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="end|bottom"
                android:alpha="0.12"
                android:background="@drawable/leaf_pattern"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/back_arrow_white"
                app:navigationIconTint="#1B5E20"
                android:background="@android:color/transparent">

                <LinearLayout
                    android:id="@+id/toolbarCollapsedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Benefits"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20" />
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp"
                app:layout_collapseMode="parallax">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Benefits"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore and apply for benefits you're eligible for"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable Body ── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- ════════════════════════════════════════
                 SECTION 1 · Available Benefits
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_bar"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Available Benefits"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBenefitsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textSize="11sp"
                    app:chipBackgroundColor="#E8F5E9"
                    app:chipStrokeColor="#A5D6A7"
                    app:chipStrokeWidth="1dp"
                    android:textColor="#2E7D32"
                    app:chipMinHeight="28dp" />
            </LinearLayout>

            <!-- Dynamic benefit cards injected by Java -->
            <LinearLayout
                android:id="@+id/containerBenefits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ════════════════════════════════════════
                 SECTION 2 · Upload Supporting Files
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_bar"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Supporting Files"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8F5E9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Drop-zone hint -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/file_upload"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max 10 MB total · PDF, DOC, JPG accepted"
                            android:textSize="12sp"
                            android:textColor="#66BB6A"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Choose file button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickFiles"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Choose File(s)"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.04"
                        app:backgroundTint="#2E7D32"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_attach_file"
                        app:iconTint="#FFFFFF"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                    <!-- Selected files list -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_file_list"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvSelectedFiles"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No files selected"
                            android:textSize="13sp"
                            android:textColor="#4F5F52"
                            android:lineSpacingExtra="4dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E8F5E9"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_storage"
                                app:tint="#81C784"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tvTotalSize"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total: 0 B / 10 MB"
                                android:textSize="12sp"
                                android:textColor="#66BB6A" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Clear button row (Upload button removed) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearFiles"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="Clear Files"
                        android:textSize="14sp"
                        android:textColor="#2E7D32"
                        android:enabled="false"
                        app:backgroundTint="#E8F5E9"
                        app:cornerRadius="12dp"
                        app:strokeColor="#A5D6A7"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_clear"
                        app:iconTint="#2E7D32"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Selected files will be attached when you tap Apply Now on any benefit below."
                        android:textSize="11.5sp"
                        android:textColor="#90A4AE"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════
                 SECTION 3 · Application Progress
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_bar"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Application Progress"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />
            </LinearLayout>

            <!-- Overall status chip card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8F5E9"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info_outline"
                        app:tint="#43A047"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Current status"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/tvApplicationStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No active application"
                        android:textSize="12sp"
                        android:textColor="#2E7D32"
                        app:chipBackgroundColor="#E8F5E9"
                        app:chipStrokeColor="#A5D6A7"
                        app:chipStrokeWidth="1dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Per-benefit progress cards injected by Java -->
            <LinearLayout
                android:id="@+id/containerProgressCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ════════════════════════════════════════
                 SECTION 4 · Benefit History
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_bar"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Benefit History"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8F5E9"
                app:strokeWidth="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/containerBenefitHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:id="@+id/historyEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_history"
                            app:tint="#C8E6C9"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No history yet"
                            android:textSize="14sp"
                            android:textColor="#A5D6A7"
                            android:gravity="center" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom Navigation ── -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>