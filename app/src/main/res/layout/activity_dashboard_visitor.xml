<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFFFE">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Modern Header with Gradient Effect -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp"
                android:elevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back"
                        android:textColor="#A7F3D0"
                        android:textSize="14sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvDashboardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visitor's Dashboard"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="28sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"/>

                </LinearLayout>
            </RelativeLayout>

            <!-- Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <!-- Announcements Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Announcements"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#065F46"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <!-- Announcement Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/ivAnnouncement"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:scaleType="centerCrop"
                            android:background="#E8F5E9"
                            android:contentDescription="Announcement banner"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvAnnouncementTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Latest Updates"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#064E3B"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvAnnouncementDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stay informed with our latest news and updates"
                                android:textSize="14sp"
                                android:textColor="#6B7280"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Quick Links Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#065F46"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <!-- Quick Links Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <!-- First Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Benefits Card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnQuickBenefits"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#ECFDF5"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/icon_circle_green"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Benefits"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="#065F46"
                                    android:layout_marginTop="12dp"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="View perks"
                                    android:textSize="11sp"
                                    android:textColor="#10B981"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Calculator Card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnQuickCalculator"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#D1FAE5"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/icon_circle_green_dark"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Calculator"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="#065F46"
                                    android:layout_marginTop="12dp"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quick math"
                                    android:textSize="11sp"
                                    android:textColor="#059669"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Second Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Create Account Card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnCreateAccount"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#FFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/icon_circle_gray"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Create Account"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="#374151"
                                    android:layout_marginTop="12dp"
                                    android:textAlignment="center"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Get started"
                                    android:textSize="11sp"
                                    android:textColor="#6B7280"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Logout Card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnLogout"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#FEE2E2"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/icon_circle_red"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Logout"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="#991B1B"
                                    android:layout_marginTop="12dp"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sign out"
                                    android:textSize="11sp"
                                    android:textColor="#DC2626"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>