<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FFF8">

    <!-- SCROLLABLE MAIN CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report an Incident"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#166534"/>

            <!-- CATEGORY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="16dp"
                android:radius="12dp"
                android:orientation="vertical"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:textSize="16sp"/>

                <RadioGroup
                    android:id="@+id/rgCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/rbOutage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outage"
                        android:textColor="#2E7D32"
                        android:checked="true"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbDamagedPole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Damaged Pole"
                        android:textColor="#2E7D32"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbOther"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other"
                        android:textColor="#2E7D32"/>
                </RadioGroup>
            </LinearLayout>

            <!-- DESCRIPTION CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="16dp"
                android:radius="12dp"
                android:orientation="vertical"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:textSize="16sp"/>

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#F1F5F3"
                    android:gravity="top|start"
                    android:padding="12dp"
                    android:hint="Describe what happened..."
                    android:inputType="textMultiLine"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- ATTACH PHOTO CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="16dp"
                android:radius="12dp"
                android:orientation="vertical"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attach Photo"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvSelectedFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file chosen"
                    android:textColor="#666666"
                    android:layout_marginTop="10dp"/>

                <Button
                    android:id="@+id/btnChooseFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose File"
                    android:padding="10dp"
                    android:backgroundTint="#166534"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- LOCATION CARD with embedded MapView -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="16dp"
                android:radius="12dp"
                android:orientation="vertical"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:textSize="16sp"/>

                <!-- Address label (reverse-geocoded or lat/lng) -->
                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap 'Use My Location' to detect coordinates"
                    android:textColor="#444444"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="8dp"/>

                <!-- Coordinate readout -->
                <TextView
                    android:id="@+id/tvCoordinates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lat: —   Lng: —"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"/>

                <!-- "Use My Location" button -->
                <Button
                    android:id="@+id/btnUseMyLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Use My Location"
                    android:backgroundTint="#166534"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="12dp"/>

                <!-- Google MapView – user can also tap the map to pick a spot -->
                <com.google.android.gms.maps.MapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap anywhere on the map to pin a custom location."
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <!-- SUBMIT BUTTON -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Submit Report"
                android:textColor="#FFFFFF"
                android:backgroundTint="#166534"
                android:layout_marginTop="22dp"
                android:radius="12dp"/>

            <!-- STATUS TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Report Status"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1B5E20"
                android:layout_marginTop="30dp"/>

            <!-- INCIDENT HISTORY CARD -->
            <LinearLayout
                android:id="@+id/containerIncidentHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="16dp"
                android:radius="12dp"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="100dp">

                <TextView
                    android:id="@+id/tvNoIncidentsPlaceholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No incident reports yet."
                    android:textColor="#666666"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>