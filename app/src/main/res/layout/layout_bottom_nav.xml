<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:elevation="12dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvNavHomeIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#ECFDF5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <!-- Icon placeholder - replace with ImageView -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/nav_icon_home"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="11sp"
            android:textColor="#059669"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Incident Reports -->
    <LinearLayout
        android:id="@+id/navIncident"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvNavIncidentIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <!-- Icon placeholder - replace with ImageView -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/nav_icon_incident"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvNavIncident"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:gravity="center"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Calculator -->
    <LinearLayout
        android:id="@+id/navCalculator"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvNavCalculatorIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <!-- Icon placeholder - replace with ImageView -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/nav_icon_calculator"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvNavCalculator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculator"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvNavProfileIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <!-- Icon placeholder - replace with ImageView -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/nav_icon_profile"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvNavProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Logout -->
    <LinearLayout
        android:id="@+id/navLogout"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvNavLogoutIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <!-- Icon placeholder - replace with ImageView -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/nav_icon_logout"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvNavLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textSize="11sp"
            android:textColor="#DC2626"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>