<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvMeterName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meter #1234567"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/tvMeterStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active"
        android:layout_marginTop="4dp"
        android:background="#E6FFED"
        android:padding="4dp"/>

    <TextView
        android:id="@+id/tvLastReading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last Reading: 57123 kWh"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvPredictedConsumption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Predicted next month: 120.5 kWh"
        android:layout_marginTop="4dp"
        android:textStyle="italic"/>

    <TextView
        android:id="@+id/tvBillAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bill: ₱510.23"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnViewHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View History"
        android:layout_marginTop="12dp"/>
</LinearLayout>
