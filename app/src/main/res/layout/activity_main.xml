<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Top Spacer for better centering -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- App Icon with green background circle -->
        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:elevation="8dp"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="#4CAF50">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.02" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subtitle"
            android:textSize="15sp"
            android:textColor="#66BB6A"
            android:layout_marginBottom="48dp" />

        <!-- Email Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:autofillHints="emailAddress"
                android:background="@android:color/transparent"
                android:padding="16dp"
                android:textColor="#1B5E20"
                android:textColorHint="#81C784"
                android:textSize="16sp"
                android:drawableStart="@android:drawable/sym_action_email"
                android:drawableTint="#4CAF50"
                android:drawablePadding="12dp" />
        </androidx.cardview.widget.CardView>

        <!-- Password Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:padding="16dp"
                android:textColor="#1B5E20"
                android:textColorHint="#81C784"
                android:textSize="16sp"
                android:drawableStart="@android:drawable/ic_lock_lock"
                android:drawableTint="#4CAF50"
                android:drawablePadding="12dp" />
        </androidx.cardview.widget.CardView>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password"
            android:textColor="#66BB6A"
            android:textSize="14sp"
            android:layout_gravity="end"
            android:layout_marginBottom="32dp"
            android:padding="8dp" />

        <!-- Login Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="4dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#4CAF50">

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_login"
                android:background="@android:color/transparent"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp"
                android:letterSpacing="0.05" />
        </androidx.cardview.widget.CardView>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#C8E6C9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OR"
                android:textColor="#81C784"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#C8E6C9" />
        </LinearLayout>

        <!-- Signup Link -->
        <Button
            android:id="@+id/tvCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account"
            android:background="@android:color/transparent"
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:letterSpacing="0.05" />

        <!-- Visitor Mode Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="2dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#4CAF50"
            app:strokeWidth="2dp">

            <Button
                android:id="@+id/btnVisitorMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Continue as Visitor"
                android:background="@android:color/transparent"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="14dp"
                android:letterSpacing="0.05" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="2dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#4CAF50"
            app:strokeWidth="2dp">

            <Button
                android:id="@+id/btnQrlogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login with QR"
                android:background="@android:color/transparent"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="14dp"
                android:letterSpacing="0.05" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>