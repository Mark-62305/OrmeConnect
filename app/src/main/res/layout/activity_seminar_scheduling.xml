<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F4">

    <!-- ══════════════════════════════════════════════
         TOP APP BAR
    ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:background="#166534"
        android:elevation="6dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Schedule a Seminar"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="4dp"/>

        <!-- Step indicator pill -->
        <TextView
            android:id="@+id/tvStepLabel"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Step 1 of 3"
            android:textColor="#166534"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         SCROLLABLE CONTENT
    ══════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomProgressCard"
        android:overScrollMode="never"
        android:scrollbarStyle="outsideOverlay"
        android:descendantFocusability="afterDescendants">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Orientation for New Members"
                    android:textColor="#166534"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Which includes:\n  Guidelines\n  Meter\n  Discounts\n  etc."
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅  Date &amp; Time"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#14532D"
                android:letterSpacing="0.04"/>

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#22C55E"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:elevation="3dp"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <!-- ── Seminar Date label + selected badge ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Seminar Date"
                        android:textSize="13sp"
                        android:textColor="#166534"
                        android:textStyle="bold"/>

                    <!-- Live selected date badge -->
                    <TextView
                        android:id="@+id/tvSeminarDate"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Not selected"
                        android:textColor="#166534"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>

                <!-- ── Inline CalendarView ── -->
                <CalendarView
                    android:id="@+id/calendarViewSeminar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dateTextAppearance="@android:style/TextAppearance.Small"
                    android:firstDayOfWeek="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="16dp"/>
                <!-- ── Divider ── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9"
                    android:layout_marginBottom="16dp"/>

                <!-- Time Row: Start & End -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Start Time -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start Time"
                            android:textSize="13sp"
                            android:textColor="#166534"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvStartTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="08:00 AM"
                                android:textColor="#AAAAAA"
                                android:textSize="13sp"
                                android:paddingStart="12dp"
                                android:clickable="true"
                                android:focusable="true"/>

                            <ImageView
                                android:id="@+id/btnPickStartTime"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#166534"
                                android:padding="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- End Time -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End Time"
                            android:textSize="13sp"
                            android:textColor="#166534"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvEndTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="05:00 PM"
                                android:textColor="#AAAAAA"
                                android:textSize="13sp"
                                android:paddingStart="12dp"
                                android:clickable="true"
                                android:focusable="true"/>

                            <ImageView
                                android:id="@+id/btnPickEndTime"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#166534"
                                android:padding="6dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════
         BOTTOM PROGRESS CARD (fixed)
    ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomProgressCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:elevation="12dp"
        android:layout_alignParentBottom="true">

        <!-- Progress Label Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvProgressTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Admin Approval"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#14532D"/>

            <!-- shows current approval status text -->
            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRAFT"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#166534"/>
        </LinearLayout>

        <!-- Segmented step dots (change labels to approval stages) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp"
            android:weightSum="3">

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <View
                    android:id="@+id/stepBar1"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="#22C55E"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submitted"
                    android:textSize="10sp"
                    android:textColor="#166534"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">

                <View
                    android:id="@+id/stepBar2"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="#BBF7D0"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="10sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="6dp">

                <View
                    android:id="@+id/stepBar3"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved"
                    android:textSize="10sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ProgressBar: start at 0 for draft -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#22C55E"
            android:progressBackgroundTint="#E5E7EB"
            android:layout_marginBottom="16dp"/>

        <!-- Submit Button label -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Submit Schedule Request"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#166534"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</RelativeLayout>