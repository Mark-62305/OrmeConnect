<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FDF4"
    android:forceDarkAllowed="false">

    <!-- ══════════════════════════════════════════════
         TOP APP BAR
    ══════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:contentScrim="#FFFFFF"
                app:statusBarScrim="#FFFFFF">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero"
                    app:layout_collapseMode="parallax" />

                <View
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="end|bottom"
                    android:alpha="0.12"
                    android:background="@drawable/leaf_pattern"
                    app:layout_collapseMode="parallax" />

                <androidx.appcompat.widget.Toolbar
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:background="@android:color/transparent"
                    app:layout_collapseMode="pin">
                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Back"
                            android:padding="10dp"
                            android:src="@drawable/back_arrow_white"
                            app:tint="#1B5E20" />

                        <TextView
                            android:id="@+id/tvStepLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/bg_file_list"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Step 1 of 3"
                            android:textColor="#0F5132"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                </androidx.appcompat.widget.Toolbar>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="20dp"
                    app:layout_collapseMode="parallax">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Schedule a Seminar"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orientation &amp; onboarding for new members."
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════
         SCROLLABLE CONTENT
    ══════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomProgressCard"
        android:overScrollMode="never"
        android:scrollbarStyle="outsideOverlay"
        android:descendantFocusability="afterDescendants">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- ══════════════════════════════════════════════
                 EXISTING REQUEST INFO CARD (hidden by default)
                 Shown when member has a pending/approved/rejected request
            ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/cardRequestInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginBottom="20dp"
                android:elevation="2dp"
                android:visibility="gone">

                <!-- Card header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#0F5132"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="YOUR REQUEST"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvRequestStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="PENDING"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#0F5132"
                        android:background="#DCFCE7"/>
                </LinearLayout>

                <!-- Submitted date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SUBMITTED ON"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tvRequestSubmittedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#374151"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Seminar date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SEMINAR DATE"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tvRequestSeminarDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#0F5132"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Time row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TIME"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tvRequestTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#374151"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Approved date row (only visible when approved) -->
                <LinearLayout
                    android:id="@+id/rowApprovedDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="APPROVED ON"
                        android:textColor="#15803D"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tvApprovedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#15803D"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Rejected remarks row (only visible when rejected) -->
                <LinearLayout
                    android:id="@+id/rowRemarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="REMARKS"
                        android:textColor="#EF4444"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tvRemarks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#EF4444"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Bottom padding -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="10dp"/>

            </LinearLayout>

            <!-- ── Seminar Info Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="#DCFCE7"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="SELECTED SEMINAR"
                    android:textColor="#15803D"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Orientation for New Members"
                    android:textColor="#0F5132"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="6dp"
                        android:text="Guidelines"
                        android:textColor="#15803D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="6dp"
                        android:text="Meter"
                        android:textColor="#15803D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="6dp"
                        android:text="Discounts"
                        android:textColor="#15803D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="+ more"
                        android:textColor="#15803D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Section Header: Date & Time ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="10dp"
                    android:background="#DCFCE7">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#166534"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date &amp; Time"
                    android:textColor="#0F5132"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <!-- ── Date & Calendar Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SEMINAR DATE"
                        android:textColor="#15803D"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvSeminarDate"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Not selected"
                        android:textColor="#15803D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#DCFCE7"/>
                </LinearLayout>

                <CalendarView
                    android:id="@+id/calendarViewSeminar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dateTextAppearance="@android:style/TextAppearance.Small"
                    android:firstDayOfWeek="2"
                    android:layout_marginBottom="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0FDF4"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="14dp"/>

                <!-- Time Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="START TIME"
                            android:textColor="#15803D"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="#F0FDF4"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:id="@+id/startTimeContainer">

                            <TextView
                                android:id="@+id/tvStartTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="08:00 AM"
                                android:textColor="#166534"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <ImageView
                                android:id="@+id/btnPickStartTime"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#22C55E"
                                android:padding="6dp"
                                android:clickable="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="END TIME"
                            android:textColor="#15803D"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="#F0FDF4"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:id="@+id/endTimeContainer">

                            <TextView
                                android:id="@+id/tvEndTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="05:00 PM"
                                android:textColor="#166534"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <ImageView
                                android:id="@+id/btnPickEndTime"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#22C55E"
                                android:padding="6dp"
                                android:clickable="false"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════
         BOTTOM PROGRESS CARD (fixed)
    ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomProgressCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="22dp"
        android:elevation="16dp"
        android:layout_alignParentBottom="true">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#DCFCE7"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvProgressTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Admin Approval"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#0F5132"/>

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="DRAFT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#15803D"
                android:background="#DCFCE7"/>
        </LinearLayout>

        <!-- Step bars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="5dp">

                <View
                    android:id="@+id/stepBar1"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:background="#22C55E"
                    android:layout_marginBottom="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submitted"
                    android:textSize="10sp"
                    android:textColor="#166534"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp">

                <View
                    android:id="@+id/stepBar2"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:background="#BBF7D0"
                    android:layout_marginBottom="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="5dp">

                <View
                    android:id="@+id/stepBar3"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Submit Schedule Request"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:backgroundTint="#0F5132"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</RelativeLayout>
