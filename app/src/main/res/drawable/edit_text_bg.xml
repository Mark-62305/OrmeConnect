<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#F0FDF4" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Border/Stroke -->
    <stroke
        android:width="2dp"
        android:color="#A7F3D0" />

    <!-- Padding -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp" />

</shape>