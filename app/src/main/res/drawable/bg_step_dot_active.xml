<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer filled circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#2E7D32" />
        </shape>
    </item>

    <!-- Inner white circle to create ring effect -->
    <item
        android:top="3dp"
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Center green dot -->
    <item
        android:top="5dp"
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp">
        <shape android:shape="oval">
            <solid android:color="#2E7D32" />
        </shape>
    </item>

</layer-list>
